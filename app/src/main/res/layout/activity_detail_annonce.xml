<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image de l'annonce -->
        <ImageView
            android:id="@+id/imageViewDetail"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_book_placeholder"
            android:background="@color/light_grey" />

        <!-- Contenu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Titre et prix -->
            <TextView
                android:id="@+id/textViewDetailTitre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Titre de l'annonce"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/textViewDetailPrix"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="99.99 €"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/design_default_color_primary"
                android:layout_marginTop="8dp" />

            <!-- Catégorie et état -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <TextView
                    android:id="@+id/textViewDetailCategorie"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Catégorie"
                    android:textSize="14sp"
                    android:background="@color/design_default_color_primary"
                    android:textColor="@color/white"
                    android:padding="8dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/textViewDetailEtat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="État"
                    android:textSize="14sp"
                    android:background="@color/design_default_color_secondary"
                    android:textColor="@color/white"
                    android:padding="8dp" />
            </LinearLayout>

            <!-- Description -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/textViewDetailDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description détaillée de l'annonce..."
                android:textSize="16sp"
                android:textColor="@color/grey"
                android:lineSpacingExtra="4dp" />

            <!-- Informations vendeur -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vendeur"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/light_grey"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/ic_book_placeholder"
                    android:background="@color/grey"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textViewDetailVendeur"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Étudiant Test"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textViewDetailDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Publié le 14/03/2026"
                        android:textSize="12sp"
                        android:textColor="@color/grey" />
                </LinearLayout>
            </LinearLayout>

            <!-- Boutons d'action -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonContacter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Contacter le vendeur"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonFavoris"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ajouter aux favoris"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
            </LinearLayout>

            <!-- Bouton retour -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonRetour"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Retour à la liste"
                android:layout_marginTop="16dp"
                style="@style/Widget.Material3.Button.TextButton" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>